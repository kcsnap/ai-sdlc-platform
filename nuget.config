<?xml version="1.0" encoding="utf-8"?>
<!--
  Feeds: nuget.org + the kcsnap GitHub Packages feed (private), which hosts the cross-repo contract
  packages (Yorrixx.Contracts.Charter — app-owned; AiSdlc.* contracts — platform-owned; ADR-XR-0001).

  Auth: the github source needs a token with read:packages.
    - CI: GITHUB_TOKEN works once this repo is granted Read under the package's "Manage Actions access".
    - Local: set GITHUB_TOKEN (e.g. `$env:GITHUB_TOKEN = gh auth token`) before restore.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="github" value="https://nuget.pkg.github.com/kcsnap/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github">
      <package pattern="Yorrixx.*" />
      <package pattern="AiSdlc.*" />
    </packageSource>
  </packageSourceMapping>
  <packageSourceCredentials>
    <github>
      <add key="Username" value="kcsnap" />
      <add key="ClearTextPassword" value="%GITHUB_TOKEN%" />
    </github>
  </packageSourceCredentials>
</configuration>
