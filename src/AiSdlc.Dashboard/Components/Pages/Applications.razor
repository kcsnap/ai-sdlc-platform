@page "/applications"
@page "/"
@rendermode InteractiveServer
@inject DashboardEventBus Bus
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>SDLC pipeline runs</PageTitle>

@{
    var apps = ApplicationSummariser.Summarise(_events);
}

<section class="controls">
    <h1>SDLC pipeline runs</h1>
    <p class="muted">GitHub repos that have produced AI-SDLC audit events. For user-generated apps in the Yorrixx app builder, see <a href="/users">Users</a>.</p>
    <div class="meta">
        <span class="counter">@apps.Count repo@(apps.Count == 1 ? "" : "s")</span>
    </div>
</section>

@if (apps.Count == 0)
{
    <p class="empty">No applications yet. Wire a GitHub repository to the AI SDLC platform and open an issue to see it appear here.</p>
}
else
{
    <table class="feed applications">
        <thead>
            <tr>
                <th>Application</th>
                <th>Health</th>
                <th>Runs</th>
                <th>Breakdown</th>
                <th>Latest run</th>
                <th>Last activity (UTC)</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var app in apps)
            {
                <tr class="row app-row" @onclick="() => OpenApp(app.Repository)">
                    <td class="app-name">
                        <strong>@app.Repository</strong>
                        <a href="@app.RepositoryUrl"
                           target="_blank"
                           rel="noopener"
                           class="gh-link-inline"
                           title="Open repository on GitHub"
                           @onclick:stopPropagation="true">↗</a>
                    </td>
                    <td class="health">
                        <span class="chip health-@app.HealthSlug" title="@app.HealthLabel">@app.HealthLabel</span>
                    </td>
                    <td class="counts">
                        <strong>@app.TotalRuns</strong>
                        <span class="muted">@(app.TotalRuns == 1 ? "issue" : "issues")</span>
                    </td>
                    <td class="breakdown">
                        @if (app.ReleasedCount > 0)
                        {
                            <span class="chip status status-released" title="Released">✓ @app.ReleasedCount</span>
                        }
                        @if (app.RunningCount > 0)
                        {
                            <span class="chip status status-running" title="Running">● @app.RunningCount</span>
                        }
                        @if (app.FailedCount > 0)
                        {
                            <span class="chip status status-failed" title="Failed">⚠ @app.FailedCount</span>
                        }
                        @if (app.BlockedCount > 0)
                        {
                            <span class="chip status status-blocked" title="Awaiting human input">⏸ @app.BlockedCount</span>
                        }
                        @if (app.PendingCount > 0)
                        {
                            <span class="chip status status-pending" title="Pending">○ @app.PendingCount</span>
                        }
                    </td>
                    <td class="latest">
                        @if (app.LatestRun is { } latest)
                        {
                            <span class="muted">#@latest.IssueNumber</span>
                            @if (!string.IsNullOrWhiteSpace(latest.IssueTitle))
                            {
                                <span class="title-text"> @latest.IssueTitle</span>
                            }
                        }
                    </td>
                    <td class="ts">@(app.LatestActivityUtc?.UtcDateTime.ToString("MM-dd HH:mm:ss") ?? "—")</td>
                    <td class="expander">›</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private readonly List<DashboardEvent> _events = new();
    private IDisposable? _subscription;

    protected override void OnInitialized()
    {
        _events.AddRange(Bus.Snapshot());
        _subscription = Bus.Subscribe(OnBatch);
    }

    private Task OnBatch(IReadOnlyList<DashboardEvent> batch)
    {
        return InvokeAsync(() =>
        {
            foreach (var ev in batch)
            {
                _events.Insert(0, ev);
            }

            const int hardCap = 500;
            if (_events.Count > hardCap)
            {
                _events.RemoveRange(hardCap, _events.Count - hardCap);
            }

            StateHasChanged();
        });
    }

    private void OpenApp(string repository) =>
        Nav.NavigateTo($"/issues?repo={Uri.EscapeDataString(repository)}");

    public void Dispose() => _subscription?.Dispose();
}
