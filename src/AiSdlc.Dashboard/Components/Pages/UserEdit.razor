@page "/users/edit"
@rendermode InteractiveServer
@using AiSdlc.Dashboard.Services.YorrixxAdmin
@inject IYorrixxAdminClient AdminClient

<PageTitle>Edit user · @Email</PageTitle>

<section class="controls">
    <h1>Edit user</h1>
    <div class="meta">
        <a href="/users" class="nav-link">← All users</a>
    </div>
</section>

@if (_error is not null)
{
    <p class="empty">@_error</p>
}
else if (!_loaded)
{
    <p class="empty">Loading…</p>
}
else if (_user is null)
{
    <p class="empty">User not found.</p>
}
else
{
    <form @onsubmit="Save" @onsubmit:preventDefault class="edit-form">
        <dl class="user-detail">
            <dt>Email</dt>
            <dd><strong>@_user.Email</strong></dd>

            <dt>Display name</dt>
            <dd>@(_user.DisplayName ?? "—")</dd>

            <dt>Created (UTC)</dt>
            <dd>@_user.CreatedAt.UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss")</dd>

            <dt>Last sign-in (UTC)</dt>
            <dd>@(_user.LastSignInAt?.UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss") ?? "—")</dd>

            <dt>Status</dt>
            <dd>@(_user.Status ?? "—")</dd>

            <dt>Applications in use</dt>
            <dd><strong>@_user.ApplicationCount</strong></dd>
        </dl>

        <div class="field">
            <label for="quota"><strong>Application quota</strong></label>
            <input id="quota" type="number" min="0" @bind="_quota" @bind:event="oninput" />
            <small class="muted">Maximum number of applications this user is allowed to create. Default is 1.</small>
            @if (_quota < _user.ApplicationCount)
            {
                <p class="muted">
                    Note: setting the quota below the current count (@_user.ApplicationCount) does not delete
                    existing apps. The user just can't create new ones until they fall back under the limit.
                </p>
            }
        </div>

        @if (_saveError is not null)
        {
            <p class="empty">@_saveError</p>
        }
        @if (_saved)
        {
            <p class="muted">Saved.</p>
        }

        <div class="actions">
            <button type="submit" disabled="@_saving">@(_saving ? "Saving…" : "Save")</button>
            <a href="/users" class="nav-link">Cancel</a>
        </div>
    </form>
}

@code {
    [SupplyParameterFromQuery] public string? Email { get; set; }

    private YorrixxUser? _user;
    private int _quota;
    private bool _loaded;
    private bool _saving;
    private bool _saved;
    private string? _error;
    private string? _saveError;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Email))
        {
            _error = "Missing email parameter.";
            _loaded = true;
            return;
        }

        try
        {
            _user = await AdminClient.GetUserAsync(Email, CancellationToken.None);
            if (_user is not null)
            {
                _quota = _user.ApplicationQuota;
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loaded = true;
        }
    }

    private async Task Save()
    {
        if (_user is null) return;

        _saving = true;
        _saveError = null;
        _saved = false;

        try
        {
            var updated = await AdminClient.UpdateUserQuotaAsync(_user.Email, _quota, CancellationToken.None);
            _user = updated;
            _quota = updated.ApplicationQuota;
            _saved = true;
        }
        catch (Exception ex)
        {
            _saveError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }
}
