@page "/issues"
@rendermode InteractiveServer
@inject DashboardEventBus Bus
@inject NavigationManager Nav
@inject IGitHubIssueLookup GitHubLookup
@implements IDisposable

<PageTitle>Issues@(string.IsNullOrEmpty(_repoFilter) ? "" : " · " + _repoFilter)</PageTitle>

@{
    var allRuns = RunSummariser.Summarise(_events);

    // Optional ?repo=... filter scopes the list to a single application.
    var scoped = string.IsNullOrWhiteSpace(_repoFilter)
        ? allRuns
        : allRuns.Where(r => string.Equals(r.Repository, _repoFilter, StringComparison.OrdinalIgnoreCase)).ToArray();

    var filtered = string.IsNullOrWhiteSpace(_filterText)
        ? scoped
        : scoped.Where(r =>
            r.Repository.Contains(_filterText.Trim(), StringComparison.OrdinalIgnoreCase) ||
            r.IssueNumber.ToString().Contains(_filterText.Trim(), StringComparison.OrdinalIgnoreCase) ||
            r.LatestActor.Contains(_filterText.Trim(), StringComparison.OrdinalIgnoreCase) ||
            r.LatestSummary.Contains(_filterText.Trim(), StringComparison.OrdinalIgnoreCase) ||
            (TitleFor(r)?.Contains(_filterText.Trim(), StringComparison.OrdinalIgnoreCase) ?? false))
            .ToArray();

    var totalPages = Math.Max(1, (int)Math.Ceiling(filtered.Count / (double)PageSize));
    if (_page >= totalPages) _page = totalPages - 1;
    if (_page < 0) _page = 0;
    var pageItems = filtered.Skip(_page * PageSize).Take(PageSize).ToArray();
}

<section class="controls">
    @if (!string.IsNullOrWhiteSpace(_repoFilter))
    {
        <div class="breadcrumbs">
            <a href="/applications">← Applications</a>
        </div>
    }
    <h1>
        Issues
        @if (!string.IsNullOrWhiteSpace(_repoFilter))
        {
            <span class="muted"> · @_repoFilter</span>
            <a class="clear-filter" href="/issues" title="Show all applications">clear filter ×</a>
        }
    </h1>
    <div class="meta">
        <span class="counter">@filtered.Count issue@(filtered.Count == 1 ? "" : "s")</span>
        <input class="filter" type="text" placeholder="filter (repo, issue #, title, agent…)" @bind="_filterText" @bind:event="oninput" />
    </div>
</section>

@if (filtered.Count == 0)
{
    <p class="empty">No issues yet. Open a GitHub issue against a wired repo to start a workflow run.</p>
}
else
{
    <table class="feed issues">
        <thead>
            <tr>
                <th>Issue</th>
                <th>Title</th>
                <th>Repository</th>
                <th>Status</th>
                <th>Latest activity</th>
                <th>Events</th>
                <th>Last seen (UTC)</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var run in pageItems)
            {
                var title = TitleFor(run);
                var stateLabel = StateLabelFor(run);
                var stateSlug  = StateSlugFor(run);
                <tr class="row issue-row @StatusRowClass(run.Status)" @onclick="() => OpenRun(run.RunId)">
                    <td class="issue-num">
                        <strong>#@run.IssueNumber</strong>
                        @if (run.PullRequestNumber is int pr)
                        {
                            <span class="issue">→ PR #@pr</span>
                        }
                    </td>
                    <td class="title">
                        @if (!string.IsNullOrWhiteSpace(title))
                        {
                            <a class="issue-title-link"
                               href="@run.IssueUrl"
                               target="_blank"
                               rel="noopener"
                               title="Open issue #@run.IssueNumber on GitHub"
                               @onclick:stopPropagation="true">@title</a>
                        }
                        else
                        {
                            <a class="issue-title-link muted"
                               href="@run.IssueUrl"
                               target="_blank"
                               rel="noopener"
                               title="Open issue #@run.IssueNumber on GitHub"
                               @onclick:stopPropagation="true">@TitlePlaceholderFor(run)</a>
                        }
                    </td>
                    <td class="repo">@run.Repository</td>
                    <td class="status">
                        @if (!string.IsNullOrWhiteSpace(stateLabel))
                        {
                            <span class="chip gh-state gh-state-@stateSlug"
                                  title="Issue state on GitHub">@stateLabel</span>
                        }
                        <span class="chip status status-@run.Status.ToString().ToLowerInvariant()"
                              title="Workflow status">@run.Status</span>
                        @if (run.RetryCount > 0)
                        {
                            <span class="chip retry" title="@run.RetryCount agent retr@(run.RetryCount == 1 ? "y" : "ies") on this run">retried @run.RetryCount×</span>
                        }
                        @if (run.FailedEventCount > 0 && run.Status != RunStatus.Failed)
                        {
                            <span class="chip warn" title="@run.FailedEventCount transient failure(s) recovered">@run.FailedEventCount transient</span>
                        }
                    </td>
                    <td class="latest">
                        <span class="latest-actor">@run.LatestActor</span>
                        <span class="muted">· @run.LatestAction</span>
                        <div class="muted summary">@run.LatestSummary</div>
                    </td>
                    <td class="counts">
                        @run.EventCount<span class="muted"> events · @run.AgentCount agents</span>
                    </td>
                    <td class="ts">@run.LatestActivityUtc.UtcDateTime.ToString("MM-dd HH:mm:ss")</td>
                    <td class="expander">›</td>
                </tr>
            }
        </tbody>
    </table>

    @if (totalPages > 1)
    {
        <nav class="pagination" aria-label="pagination">
            <button class="page-btn" disabled="@(_page == 0)" @onclick="() => GoTo(0)">«</button>
            <button class="page-btn" disabled="@(_page == 0)" @onclick="() => GoTo(_page - 1)">‹ Prev</button>
            <span class="page-info">Page @(_page + 1) of @totalPages</span>
            <button class="page-btn" disabled="@(_page >= totalPages - 1)" @onclick="() => GoTo(_page + 1)">Next ›</button>
            <button class="page-btn" disabled="@(_page >= totalPages - 1)" @onclick="() => GoTo(totalPages - 1)">»</button>
        </nav>
    }
}

@code {
    private const int PageSize = 10;

    private readonly List<DashboardEvent> _events = new();
    // Backfill cache: keyed by RunId → GitHub-API-fetched issue info. Audit data still wins when present.
    private readonly Dictionary<string, GitHubIssueInfo> _ghOverlay = new(StringComparer.Ordinal);
    // Tracks which RunIds have been queried and resolved (regardless of success). Lets us distinguish
    // "still fetching" from "fetched and not available".
    private readonly HashSet<string> _ghRequested = new(StringComparer.Ordinal);
    private readonly HashSet<string> _ghResolved  = new(StringComparer.Ordinal);

    private IDisposable? _subscription;
    private string _filterText = string.Empty;
    private string _repoFilter = string.Empty;
    private int _page;

    protected override void OnInitialized()
    {
        _events.AddRange(Bus.Snapshot());
        _subscription = Bus.Subscribe(OnBatch);
        Nav.LocationChanged += OnLocationChanged;
        ReadRepoFromUrl();

        // Fire-and-forget: kick off the GitHub backfill once events are loaded.
        _ = BackfillTitlesAsync();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(() =>
        {
            ReadRepoFromUrl();
            StateHasChanged();
        });
    }

    private void ReadRepoFromUrl()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        _repoFilter = query.TryGetValue("repo", out var values) ? values.ToString() : string.Empty;
        _page = 0;  // reset pagination when filter changes
    }

    private Task OnBatch(IReadOnlyList<DashboardEvent> batch)
    {
        return InvokeAsync(async () =>
        {
            foreach (var ev in batch)
            {
                _events.Insert(0, ev);
            }

            const int hardCap = 500;
            if (_events.Count > hardCap)
            {
                _events.RemoveRange(hardCap, _events.Count - hardCap);
            }

            StateHasChanged();

            // New runs might have arrived — try to backfill any new ones.
            await BackfillTitlesAsync();
        });
    }

    private async Task BackfillTitlesAsync()
    {
        var runs = RunSummariser.Summarise(_events);
        var needed = runs
            .Where(r => (string.IsNullOrWhiteSpace(r.IssueTitle) || string.IsNullOrWhiteSpace(r.IssueState))
                        && _ghRequested.Add(r.RunId))
            .ToArray();

        foreach (var r in needed)
        {
            var info = await GitHubLookup.GetIssueAsync(r.Repository, r.IssueNumber, CancellationToken.None);
            if (info is not null)
            {
                _ghOverlay[r.RunId] = info;
            }
            _ghResolved.Add(r.RunId);
            await InvokeAsync(StateHasChanged);
        }
    }

    private string TitlePlaceholderFor(RunSummary r) =>
        _ghResolved.Contains(r.RunId) ? "(unavailable on GitHub)" : "(fetching from GitHub…)";

    private string? TitleFor(RunSummary r)
    {
        if (!string.IsNullOrWhiteSpace(r.IssueTitle)) return r.IssueTitle;
        return _ghOverlay.TryGetValue(r.RunId, out var info) ? info.Title : null;
    }

    private string? StateLabelFor(RunSummary r)
    {
        if (r.IssueStateLabel is { } fromAudit) return fromAudit;
        if (!_ghOverlay.TryGetValue(r.RunId, out var info)) return null;
        return FormatStateLabel(info.State, info.StateReason);
    }

    private string StateSlugFor(RunSummary r)
    {
        if (r.IssueStateSlug != "none") return r.IssueStateSlug;
        if (!_ghOverlay.TryGetValue(r.RunId, out var info)) return "none";
        return SlugFor(info.State, info.StateReason);
    }

    private static string? FormatStateLabel(string? state, string? reason)
    {
        if (string.IsNullOrWhiteSpace(state)) return null;
        var s = state.Trim().ToLowerInvariant();
        if (s != "closed") return char.ToUpperInvariant(s[0]) + s[1..];
        return reason?.Trim().ToLowerInvariant() switch
        {
            "completed"   => "Closed as completed",
            "not_planned" => "Closed as not planned",
            "duplicate"   => "Closed as duplicate",
            "reopened"    => "Reopened",
            _             => "Closed"
        };
    }

    private static string SlugFor(string? state, string? reason)
    {
        var label = FormatStateLabel(state, reason);
        return label switch
        {
            null                            => "none",
            "Open"                          => "open",
            "Reopened"                      => "open",
            "Closed as not planned"         => "closed-not-planned",
            "Closed as duplicate"           => "closed-not-planned",
            _ when label.StartsWith("Closed", StringComparison.Ordinal) => "closed",
            _                               => "none"
        };
    }

    private void OpenRun(string runId) =>
        Nav.NavigateTo($"/runs/{Uri.EscapeDataString(runId)}");

    private void GoTo(int page) => _page = page;

    private static string StatusRowClass(RunStatus s) => s switch
    {
        RunStatus.Failed   => "row-error",
        RunStatus.Released => "row-released",
        RunStatus.Running  => "row-running",
        _                  => string.Empty
    };

    public void Dispose()
    {
        _subscription?.Dispose();
        Nav.LocationChanged -= OnLocationChanged;
    }
}
