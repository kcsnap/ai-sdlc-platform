@using AiSdlc.Dashboard.Services

@switch (State)
{
    case AgentVisualState.NotStarted:
        <svg class="agent-avatar avatar-rest" viewBox="0 0 28 30" aria-hidden="true">
            <ellipse cx="14" cy="25" rx="7" ry="3" fill="#000" opacity="0.15"/>
            <path d="M7 24 Q 7 16 14 16 Q 21 16 21 24 Z" fill="currentColor" opacity="0.55"/>
            <circle cx="14" cy="11" r="8" fill="currentColor" opacity="0.9"/>
            <path d="M9.5 11 Q 11 9.5 12.5 11" stroke="#0d1117" stroke-width="1.1" fill="none" stroke-linecap="round"/>
            <path d="M15.5 11 Q 17 9.5 18.5 11" stroke="#0d1117" stroke-width="1.1" fill="none" stroke-linecap="round"/>
            <path d="M12 14 Q 14 15 16 14" stroke="#0d1117" stroke-width="0.9" fill="none" stroke-linecap="round"/>
        </svg>
        break;

    case AgentVisualState.InProgress:
        <svg class="agent-avatar avatar-working" viewBox="0 0 28 30" aria-hidden="true">
            <ellipse cx="14" cy="25" rx="7" ry="3" fill="#000" opacity="0.15"/>
            <path d="M7 24 Q 7 16 14 16 Q 21 16 21 24 Z" fill="currentColor" opacity="0.6"/>
            <circle cx="14" cy="11" r="8" fill="currentColor" opacity="0.95"/>
            <path d="M8.5 9.5 L 11.5 11" stroke="#0d1117" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M16.5 11 L 19.5 9.5" stroke="#0d1117" stroke-width="1.4" stroke-linecap="round"/>
            <ellipse cx="11" cy="11" rx="0.9" ry="0.9" fill="#0d1117"/>
            <ellipse cx="17" cy="11" rx="0.9" ry="0.9" fill="#0d1117"/>
            <path d="M11.5 14.5 L 16.5 14.5" stroke="#0d1117" stroke-width="1" stroke-linecap="round"/>
            <path class="sweat" d="M22 6 Q 23.6 9 22 11 Q 20.4 9 22 6 Z" fill="#7ec5ff" stroke="#3a8fd9" stroke-width="0.3"/>
        </svg>
        break;

    case AgentVisualState.Complete:
        <svg class="agent-avatar avatar-happy" viewBox="0 0 28 30" aria-hidden="true">
            <ellipse cx="14" cy="25" rx="7" ry="3" fill="#000" opacity="0.15"/>
            <path d="M7 24 Q 7 16 14 16 Q 21 16 21 24 Z" fill="currentColor" opacity="0.6"/>
            <circle cx="14" cy="11" r="8" fill="currentColor" opacity="0.95"/>
            <path d="M9 11.5 Q 10.5 9 12 11.5" stroke="#0d1117" stroke-width="1.3" fill="none" stroke-linecap="round"/>
            <path d="M16 11.5 Q 17.5 9 19 11.5" stroke="#0d1117" stroke-width="1.3" fill="none" stroke-linecap="round"/>
            <path d="M10.5 13.5 Q 14 16.5 17.5 13.5" stroke="#0d1117" stroke-width="1.1" fill="none" stroke-linecap="round"/>
            <ellipse cx="8" cy="14.5" rx="1.4" ry="0.9" fill="#ff9eb1" opacity="0.7"/>
            <ellipse cx="20" cy="14.5" rx="1.4" ry="0.9" fill="#ff9eb1" opacity="0.7"/>
            <path class="sparkle sparkle-a" d="M3 5 L 4 7 L 6 8 L 4 9 L 3 11 L 2 9 L 0 8 L 2 7 Z" fill="#ffd633"/>
            <path class="sparkle sparkle-b" d="M24 4 L 24.7 5.3 L 26 6 L 24.7 6.7 L 24 8 L 23.3 6.7 L 22 6 L 23.3 5.3 Z" fill="#ffd633"/>
        </svg>
        break;

    case AgentVisualState.Failed:
        <svg class="agent-avatar avatar-failed" viewBox="0 0 28 30" aria-hidden="true">
            <ellipse cx="14" cy="25" rx="7" ry="3" fill="#000" opacity="0.15"/>
            <path d="M7 24 Q 7 16 14 16 Q 21 16 21 24 Z" fill="currentColor" opacity="0.55"/>
            <circle cx="14" cy="11" r="8" fill="currentColor" opacity="0.9"/>
            <path d="M8.5 9 L 11.5 12 M 11.5 9 L 8.5 12" stroke="#0d1117" stroke-width="1.1" stroke-linecap="round"/>
            <path d="M16.5 9 L 19.5 12 M 19.5 9 L 16.5 12" stroke="#0d1117" stroke-width="1.1" stroke-linecap="round"/>
            <path d="M11 15 Q 14 13 17 15" stroke="#0d1117" stroke-width="1.1" fill="none" stroke-linecap="round"/>
            <path d="M14 1.5 L 12.5 4 L 15.5 4 Z" fill="#f85149" opacity="0.85"/>
        </svg>
        break;

    case AgentVisualState.Skipped:
        <svg class="agent-avatar avatar-skipped" viewBox="0 0 28 30" aria-hidden="true">
            <ellipse cx="14" cy="25" rx="7" ry="3" fill="#000" opacity="0.12"/>
            <path d="M7 24 Q 7 16 14 16 Q 21 16 21 24 Z" fill="currentColor" opacity="0.4"/>
            <circle cx="14" cy="11" r="8" fill="currentColor" opacity="0.7"/>
            <path d="M9 11.5 Q 10.5 12.5 12 11.5" stroke="#0d1117" stroke-width="1.1" fill="none" stroke-linecap="round"/>
            <path d="M16 11.5 Q 17.5 12.5 19 11.5" stroke="#0d1117" stroke-width="1.1" fill="none" stroke-linecap="round"/>
            <path d="M12 14.5 Q 14 14 16 14.5" stroke="#0d1117" stroke-width="0.8" fill="none" stroke-linecap="round"/>
            <text class="zzz" x="20" y="7" font-family="-apple-system, Segoe UI, sans-serif" font-size="6" font-weight="700" fill="#8b949e">z</text>
            <text class="zzz" x="23" y="4" font-family="-apple-system, Segoe UI, sans-serif" font-size="4.5" font-weight="700" fill="#8b949e" opacity="0.7">z</text>
        </svg>
        break;
}

@code {
    [Parameter, EditorRequired] public AgentVisualState State { get; set; }
}
