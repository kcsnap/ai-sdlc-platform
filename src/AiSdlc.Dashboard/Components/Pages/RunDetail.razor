@page "/runs/{RunIdParam}"
@rendermode InteractiveServer
@inject DashboardEventBus Bus
@inject PromptArtefactLoader PromptLoader
@inject NavigationManager Nav
@inject IGitHubIssueLookup GitHubLookup
@implements IDisposable

<PageTitle>Run · @RunIdParam</PageTitle>

@{
    var runEvents = _events.Where(e => string.Equals(e.RunId, _decodedRunId, StringComparison.Ordinal)).ToArray();
    // On this page only: order rows chronologically (oldest top → newest bottom) so the table reads
    // naturally alongside the left-to-right workflow diagram. Activity.razor stays newest-first.
    var rows = FeedGrouper.Group(runEvents)
                          .OrderBy(r => r.Display.TimestampUtc)
                          .ToArray();
    var summary = RunSummariser.Summarise(runEvents).FirstOrDefault();
    var stages  = WorkflowStateBuilder.Build(runEvents, summary?.Status ?? RunStatus.Unknown);

    var title      = summary is null ? null : (!string.IsNullOrWhiteSpace(summary.IssueTitle) ? summary.IssueTitle : _ghInfo?.Title);
    var stateLabel = summary?.IssueStateLabel ?? FormatStateLabel(_ghInfo?.State, _ghInfo?.StateReason);
    var stateSlug  = summary is not null && summary.IssueStateSlug != "none"
        ? summary.IssueStateSlug
        : SlugFor(_ghInfo?.State, _ghInfo?.StateReason);
}

<section class="controls">
    <div class="breadcrumbs">
        <a href="/issues">← Issues</a>
    </div>
    <h1>
        @if (summary is not null)
        {
            <a class="issue-title-link" href="@summary.IssueUrl" target="_blank" rel="noopener" title="Open on GitHub">#@summary.IssueNumber</a>
            @if (!string.IsNullOrWhiteSpace(title))
            {
                <span class="title-text"> @title</span>
            }
            <span class="muted"> · @summary.Repository</span>
        }
        else
        {
            <span class="muted">@_decodedRunId</span>
        }
    </h1>
    @if (summary is not null)
    {
        <div class="run-meta">
            @if (!string.IsNullOrWhiteSpace(stateLabel))
            {
                <span class="chip gh-state gh-state-@stateSlug" title="Issue state on GitHub">@stateLabel</span>
            }
            <span class="chip status status-@summary.Status.ToString().ToLowerInvariant()" title="Workflow status">@summary.Status</span>
            @if (summary.PullRequestNumber is int pr)
            {
                <span class="chip decision">PR #@pr</span>
            }
            <span class="muted">@summary.EventCount events · @summary.AgentCount agents · @rows.Length rows</span>
            @if (summary.RetryCount > 0)
            {
                <span class="chip retry">@summary.RetryCount retr@(summary.RetryCount == 1 ? "y" : "ies")</span>
            }
            <span class="muted">First: @summary.FirstActivityUtc.UtcDateTime.ToString("MM-dd HH:mm:ss")</span>
            <span class="muted">Latest: @summary.LatestActivityUtc.UtcDateTime.ToString("MM-dd HH:mm:ss")</span>
        </div>
    }
</section>

@if (rows.Length == 0)
{
    <p class="empty">No events found for this run yet. (RunId: <code>@_decodedRunId</code>)</p>
}
else
{
    <WorkflowDiagram Stages="stages" />

    <table class="feed">
        <thead>
            <tr>
                <th>Time (UTC)</th>
                <th>Repository</th>
                <th>API</th>
                <th>Agent</th>
                <th>Action</th>
                <th>Risk / Decision</th>
                <th>Summary</th>
                <th>GitHub</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in rows)
            {
                <EventRow Row="row"
                          IsExpanded="_expandedId == row.Id"
                          OnToggle="() => Toggle(row.Id)"
                          PromptLoader="PromptLoader" />
            }
        </tbody>
    </table>
}

@code {
    [Parameter] public string RunIdParam { get; set; } = string.Empty;

    private string _decodedRunId = string.Empty;
    private readonly List<DashboardEvent> _events = new();
    private GitHubIssueInfo? _ghInfo;
    private bool _ghRequested;
    private IDisposable? _subscription;
    private string? _expandedId;

    protected override void OnInitialized()
    {
        _decodedRunId = Uri.UnescapeDataString(RunIdParam);
        _events.AddRange(Bus.Snapshot());
        _subscription = Bus.Subscribe(OnBatch);
        _ = TryBackfillFromGitHubAsync();
    }

    protected override void OnParametersSet() =>
        _decodedRunId = Uri.UnescapeDataString(RunIdParam);

    private async Task TryBackfillFromGitHubAsync()
    {
        if (_ghRequested) return;

        var runEvents = _events.Where(e => string.Equals(e.RunId, _decodedRunId, StringComparison.Ordinal)).ToArray();
        var summary   = RunSummariser.Summarise(runEvents).FirstOrDefault();
        if (summary is null) return;
        if (!string.IsNullOrWhiteSpace(summary.IssueTitle) && !string.IsNullOrWhiteSpace(summary.IssueState))
        {
            return;  // already complete from audit
        }

        _ghRequested = true;
        _ghInfo = await GitHubLookup.GetIssueAsync(summary.Repository, summary.IssueNumber, CancellationToken.None);
        await InvokeAsync(StateHasChanged);
    }

    private static string? FormatStateLabel(string? state, string? reason)
    {
        if (string.IsNullOrWhiteSpace(state)) return null;
        var s = state.Trim().ToLowerInvariant();
        if (s != "closed") return char.ToUpperInvariant(s[0]) + s[1..];
        return reason?.Trim().ToLowerInvariant() switch
        {
            "completed"   => "Closed as completed",
            "not_planned" => "Closed as not planned",
            "duplicate"   => "Closed as duplicate",
            "reopened"    => "Reopened",
            _             => "Closed"
        };
    }

    private static string SlugFor(string? state, string? reason)
    {
        var label = FormatStateLabel(state, reason);
        return label switch
        {
            null                            => "none",
            "Open"                          => "open",
            "Reopened"                      => "open",
            "Closed as not planned"         => "closed-not-planned",
            "Closed as duplicate"           => "closed-not-planned",
            _ when label.StartsWith("Closed", StringComparison.Ordinal) => "closed",
            _                               => "none"
        };
    }

    private Task OnBatch(IReadOnlyList<DashboardEvent> batch)
    {
        return InvokeAsync(async () =>
        {
            foreach (var ev in batch)
            {
                _events.Insert(0, ev);
            }

            const int hardCap = 500;
            if (_events.Count > hardCap)
            {
                _events.RemoveRange(hardCap, _events.Count - hardCap);
            }

            StateHasChanged();
            await TryBackfillFromGitHubAsync();
        });
    }

    private void Toggle(string id) => _expandedId = _expandedId == id ? null : id;

    public void Dispose() => _subscription?.Dispose();
}
