{
  "name": "branch-naming-issue-link",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [],
  "conditions": {
    "ref_name": {
      "include": ["~ALL"],
      "exclude": ["refs/heads/main"]
    }
  },
  "rules": [
    {
      "type": "branch_name_pattern",
      "parameters": {
        "operator": "regex",
        "pattern": "^(ai|feat|fix|docs|chore)/\\d+-[a-z0-9][a-z0-9-]*$",
        "name": "Branch name must follow {type}/{issue#}-{slug}",
        "negate": false
      }
    }
  ]
}
